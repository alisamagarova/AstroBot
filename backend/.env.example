# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/astrobot

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=123456789:AAxxxx

# Shared secret for bot → backend internal calls (generate: openssl rand -hex 32)
BOT_SECRET=change_me_to_random_secret

# URL Mini App (GitHub Pages) — для кнопки «Открыть» в боте
MINI_APP_URL=https://alisamagarova.github.io/AstroBot/

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development   # в dev-режиме разрешён заголовок X-Dev-Tg-Id (без HMAC)
